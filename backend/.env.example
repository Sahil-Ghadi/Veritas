# Application Environment
APP_ENV=production
ORIGINS_LIST=https://your-frontend-url.vercel.app

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here
LLM_MODEL=gemini-2.5-flash

# Redis (for task queue - use Upstash free tier)
REDIS_URL=redis://default:your_password@your-redis-url.upstash.io:6379

# Twilio (for WhatsApp integration)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Tavily API (for web search)
TAVILY_API_KEY=your_tavily_api_key

# Firebase Service Account
# In production, use base64 encoded content or secret management
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json
